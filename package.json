{
  "name": "momenpix-tests",
  "version": "1.0.0",
  "scripts": {
    "test:static": "node tests/check-index.js",
    "test:rules": "jest tests/firestore-rules.test.js --testTimeout=30000",
    "test:ui": "playwright test tests/ui.spec.js --config=playwright.config.js",
    "test": "npm run test:static && npm run test:rules && npm run test:ui"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "@playwright/test": "^1.44.0",
    "firebase-admin": "^12.0.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
