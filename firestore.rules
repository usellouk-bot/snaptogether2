rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /events/{eventCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerId
                    && request.resource.data.paid == resource.data.paid;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      match /photos/{photoId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.uploaderUid == request.auth.uid;
        allow update: if request.auth != null
                      && request.auth.uid == resource.data.uploaderUid;
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/events/$(eventCode)).data.ownerId == request.auth.uid;
      }
    }
  }
}
